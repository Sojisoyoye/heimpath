      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Register",
        "description": "Register a new user account.\n\nPassword requirements:\n- Minimum 8 characters\n- At least 1 uppercase letter\n- At least 1 number\n\nReturns the created user (without password).",
        "operationId": "auth-register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
